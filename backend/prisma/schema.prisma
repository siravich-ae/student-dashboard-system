generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  studentCode  String?  @unique
  username     String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  studentId    String?  @unique
  teacherGroup String?
  createdAt    DateTime @default(now())
  student      Student? @relation(fields: [studentId], references: [id])
}

model Student {
  id            String             @id @default(cuid())
  studentCode   String             @unique
  firstName     String
  lastName      String
  nickname      String?
  gradeLevel    String?
  classRoom     String?
  schoolName    String?
  birthDate     DateTime?
  strengths     String?
  photoUrl      String?
  address       String?
  updatedAt     DateTime           @updatedAt
  extraNote     String?
  themeColor    String?
  parentPhone   String?
  phone         String?
  photoPublicId String?
  teacherGroup  String?
  achievements  Achievement[]
  gradeRecords  GradeRecord[]
  overviewItems OverviewItem[]
  choices       UniversityChoice[]
  user          User?
}

model UniversityChoice {
  id             String  @id @default(cuid())
  studentId      String
  rank           Int
  universityName String
  facultyName    String?
  programName    String?
  student        Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, rank])
}

model OverviewItem {
  id              String   @id @default(cuid())
  studentId       String
  choiceRank      Int
  requirementType String?
  requirementText String
  hasIt           Boolean  @default(false)
  note            String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, choiceRank])
}

model Achievement {
  id          String   @id @default(cuid())
  studentId   String
  category    String
  title       String
  description String?
  hasEvidence Boolean  @default(false)
  evidenceUrl String?
  note        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, category])
}

model GradeRecord {
  id           String   @id @default(cuid())
  studentId    String
  academicYear String
  term         String
  subject      String
  grade        String
  note         String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, academicYear, term])
}

enum Role {
  TEACHER
  STUDENT
  ADMIN
}
